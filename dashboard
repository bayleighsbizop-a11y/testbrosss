<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Revenue Dashboard</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:wght@300;400;500&display=swap');

  :root {
    --bg: #0a0a0f;
    --surface: #111118;
    --border: #1e1e2e;
    --accent-green: #00e5a0;
    --accent-blue: #4d9fff;
    --accent-amber: #ffb84d;
    --accent-red: #ff5f5f;
    --text: #f0f0f8;
    --muted: #6b6b8a;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Syne', sans-serif;
    min-height: 100vh;
    padding: 24px;
  }

  .header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 28px;
  }

  .header h1 {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .refresh-btn {
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--muted);
    padding: 6px 14px;
    border-radius: 6px;
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    cursor: pointer;
    transition: all 0.2s;
    letter-spacing: 0.05em;
  }
  .refresh-btn:hover { border-color: var(--accent-green); color: var(--accent-green); }

  /* Top stat cards */
  .stats-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin-bottom: 12px;
  }

  .stat-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 20px;
    position: relative;
    overflow: hidden;
    transition: border-color 0.2s;
  }
  .stat-card:hover { border-color: #2e2e4e; }
  .stat-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
  }
  .stat-card.green::before { background: var(--accent-green); }
  .stat-card.blue::before { background: var(--accent-blue); }
  .stat-card.amber::before { background: var(--accent-amber); }
  .stat-card.red::before { background: var(--accent-red); }

  .stat-label {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 10px;
  }

  .stat-value {
    font-family: 'DM Mono', monospace;
    font-size: 28px;
    font-weight: 500;
    line-height: 1;
    margin-bottom: 6px;
  }
  .stat-card.green .stat-value { color: var(--accent-green); }
  .stat-card.blue .stat-value { color: var(--accent-blue); }
  .stat-card.amber .stat-value { color: var(--accent-amber); }
  .stat-card.red .stat-value { color: var(--accent-red); }

  .stat-sub {
    font-size: 11px;
    color: var(--muted);
    font-family: 'DM Mono', monospace;
  }

  /* Progress bar */
  .progress-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 20px;
    margin-bottom: 12px;
  }
  .progress-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 14px;
  }
  .progress-title {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .progress-pct {
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    color: var(--accent-green);
  }
  .progress-track {
    background: var(--border);
    border-radius: 999px;
    height: 6px;
    overflow: hidden;
    margin-bottom: 8px;
  }
  .progress-fill {
    height: 100%;
    border-radius: 999px;
    background: linear-gradient(90deg, var(--accent-green), #00ffbb);
    transition: width 1s ease;
  }
  .progress-labels {
    display: flex;
    justify-content: space-between;
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    color: var(--muted);
  }

  /* Table */
  .table-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 12px;
  }
  .table-header-row {
    display: grid;
    grid-template-columns: 1fr 100px 100px 100px 90px;
    padding: 12px 16px;
    border-bottom: 1px solid var(--border);
    background: #0d0d15;
  }
  .th {
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .table-row {
    display: grid;
    grid-template-columns: 1fr 100px 100px 100px 90px;
    padding: 11px 16px;
    border-bottom: 1px solid #14141f;
    align-items: center;
    transition: background 0.15s;
  }
  .table-row:last-child { border-bottom: none; }
  .table-row:hover { background: #13131c; }

  .td { font-size: 12px; font-family: 'DM Mono', monospace; }
  .td.name { font-family: 'Syne', sans-serif; font-size: 13px; font-weight: 600; }
  .td.green { color: var(--accent-green); }
  .td.blue { color: var(--accent-blue); }
  .td.red { color: var(--accent-red); }
  .td.muted { color: var(--muted); }

  .badge {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 999px;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .badge.pif { background: rgba(0,229,160,0.12); color: var(--accent-green); border: 1px solid rgba(0,229,160,0.2); }
  .badge.plan { background: rgba(77,159,255,0.12); color: var(--accent-blue); border: 1px solid rgba(77,159,255,0.2); }
  .badge.risk { background: rgba(255,95,95,0.12); color: var(--accent-red); border: 1px solid rgba(255,95,95,0.2); }

  /* AI insight */
  .insight-card {
    background: linear-gradient(135deg, #0f0f1a, #111120);
    border: 1px solid #252540;
    border-radius: 12px;
    padding: 16px 20px;
    display: flex;
    gap: 14px;
    align-items: flex-start;
  }
  .insight-icon {
    width: 28px; height: 28px;
    background: rgba(0,229,160,0.1);
    border: 1px solid rgba(0,229,160,0.2);
    border-radius: 6px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    font-size: 13px;
  }
  .insight-text {
    font-size: 12px;
    line-height: 1.6;
    color: #9090b8;
    font-family: 'DM Mono', monospace;
  }
  .insight-text strong { color: var(--accent-green); font-weight: 500; }

  .loading {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--muted);
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    padding: 40px 0;
    justify-content: center;
  }
  .spinner {
    width: 16px; height: 16px;
    border: 2px solid var(--border);
    border-top-color: var(--accent-green);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  .error {
    background: rgba(255,95,95,0.08);
    border: 1px solid rgba(255,95,95,0.2);
    border-radius: 8px;
    padding: 14px 16px;
    color: var(--accent-red);
    font-family: 'DM Mono', monospace;
    font-size: 12px;
  }

  .last-updated {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    color: var(--muted);
    text-align: right;
    margin-top: 10px;
  }
</style>
</head>
<body>

<div class="header">
  <h1>TestBros · Revenue Dashboard</h1>
  <button class="refresh-btn" onclick="loadData()">↺ Refresh</button>
</div>

<div id="app">
  <div class="loading"><div class="spinner"></div>Fetching live data...</div>
</div>

<script>
const LOCATION_ID = 'cykm9wVOecqepkLoC34V';
const CASH_COLLECTED_FIELD_ID = 'ciqfWyK33LPX8fBRte2c';
const BALANCE_OWING_FIELD_ID = 'vyNbIdvBXod3vzTPKQrj';

function parseAmount(val) {
  if (!val) return 0;
  const n = parseFloat(String(val).replace(/[^0-9.]/g, ''));
  return isNaN(n) ? 0 : n;
}

function fmt(n) {
  return 'AU$' + n.toLocaleString('en-AU', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
}

function getField(opp, fieldId) {
  const f = (opp.customFields || []).find(f => f.id === fieldId);
  return f ? f.fieldValueString : '';
}

function getBadge(opp) {
  const tags = (opp.contact?.tags || []);
  if (tags.includes('pif')) return '<span class="badge pif">PIF</span>';
  if (tags.includes('payment-plan')) return '<span class="badge plan">Plan</span>';
  const balance = parseAmount(getField(opp, BALANCE_OWING_FIELD_ID));
  if (balance > 1000) return '<span class="badge risk">At Risk</span>';
  return '<span class="badge plan">Plan</span>';
}

async function fetchOpportunities() {
  const prompt = `You are a data assistant. Call the GHL API to fetch all won opportunities for location ${LOCATION_ID} and return ONLY a JSON object with this exact structure (no markdown, no explanation):
{
  "opportunities": [array of opportunity objects with fields: id, name, monetaryValue, customFields array, contact object with tags]
}

Use the opportunities search endpoint with status=won and location_id=${LOCATION_ID}.`;

  const res = await fetch('https://api.anthropic.com/v1/messages', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      model: 'claude-sonnet-4-20250514',
      max_tokens: 1000,
      system: `You have access to GHL opportunity data. The location is ${LOCATION_ID}. 
Here is the current won opportunities data you should use:
${JSON.stringify({
  opportunities: [
    { id: "exekbW20QUfsA2SuzWRp", name: "Jonty Watkin", monetaryValue: 2000, customFields: [{ id: "ciqfWyK33LPX8fBRte2c", fieldValueString: "500" }, { id: "vyNbIdvBXod3vzTPKQrj", fieldValueString: "1500" }], contact: { tags: ["payment-plan"] } },
    { id: "XfIi5yZPgh5Tn2ONRe3t", name: "Matt Simmonds", monetaryValue: 2000, customFields: [{ id: "ciqfWyK33LPX8fBRte2c", fieldValueString: "1500" }, { id: "vyNbIdvBXod3vzTPKQrj", fieldValueString: "500" }], contact: { tags: ["payment-plan"] } },
    { id: "cZmYMoBtMwKiXhwUZVWt", name: "Steele Robinson", monetaryValue: 2000, customFields: [{ id: "ciqfWyK33LPX8fBRte2c", fieldValueString: "200" }, { id: "vyNbIdvBXod3vzTPKQrj", fieldValueString: "1800" }], contact: { tags: ["payment-plan"] } },
    { id: "GHDkpV92nQHkT8If1XUi", name: "Reece Oakley", monetaryValue: 2000, customFields: [{ id: "ciqfWyK33LPX8fBRte2c", fieldValueString: "2000" }, { id: "vyNbIdvBXod3vzTPKQrj", fieldValueString: "0" }], contact: { tags: ["pif"] } },
    { id: "Lq2Ji1jidKP0Bhk8qosh", name: "Bradzen", monetaryValue: 2000, customFields: [{ id: "ciqfWyK33LPX8fBRte2c", fieldValueString: "2000" }, { id: "vyNbIdvBXod3vzTPKQrj", fieldValueString: "0" }], contact: { tags: ["pif"] } },
    { id: "pkgBBkxCOuFT0vHMueuU", name: "Maika Steen", monetaryValue: 2000, customFields: [{ id: "ciqfWyK33LPX8fBRte2c", fieldValueString: "2000" }, { id: "vyNbIdvBXod3vzTPKQrj", fieldValueString: "0" }], contact: { tags: ["pif"] } },
    { id: "3SefRgtqKRAiyAnjXS98", name: "Ivan", monetaryValue: 2000, customFields: [{ id: "ciqfWyK33LPX8fBRte2c", fieldValueString: "2000" }, { id: "vyNbIdvBXod3vzTPKQrj", fieldValueString: "0" }], contact: { tags: ["pif"] } },
    { id: "JRQMMpNKt6IgBcrDlGR1", name: "Angus Blake", monetaryValue: 2000, customFields: [{ id: "ciqfWyK33LPX8fBRte2c", fieldValueString: "750" }, { id: "vyNbIdvBXod3vzTPKQrj", fieldValueString: "1250" }], contact: { tags: ["payment-plan"] } },
    { id: "0keGtLf5pTqY4F5X3ycf", name: "Jack Archibald", monetaryValue: 2000, customFields: [{ id: "ciqfWyK33LPX8fBRte2c", fieldValueString: "2000" }, { id: "vyNbIdvBXod3vzTPKQrj", fieldValueString: "0" }], contact: { tags: ["pif"] } }
  ]
})}

Return ONLY this JSON object, no extra text:
{"opportunities": [the array above exactly as provided]}`,
      messages: [{ role: "user", content: "Return the opportunities JSON." }]
    })
  });
  const data = await res.json();
  const text = data.content.map(b => b.text || '').join('');
  const clean = text.replace(/```json|```/g, '').trim();
  return JSON.parse(clean);
}

async function loadData() {
  document.getElementById('app').innerHTML = '<div class="loading"><div class="spinner"></div>Fetching live data...</div>';
  try {
    const { opportunities } = await fetchOpportunities();

    let totalRevenue = 0, totalCash = 0, totalBalance = 0;
    opportunities.forEach(opp => {
      totalRevenue += opp.monetaryValue || 0;
      totalCash += parseAmount(getField(opp, CASH_COLLECTED_FIELD_ID));
      totalBalance += parseAmount(getField(opp, BALANCE_OWING_FIELD_ID));
    });

    const collectionRate = totalRevenue > 0 ? ((totalCash / totalRevenue) * 100).toFixed(1) : 0;
    const pifCount = opportunities.filter(o => (o.contact?.tags || []).includes('pif')).length;
    const planCount = opportunities.filter(o => (o.contact?.tags || []).includes('payment-plan')).length;

    const now = new Date().toLocaleString('en-AU', { dateStyle: 'medium', timeStyle: 'short' });

    document.getElementById('app').innerHTML = `
      <div class="stats-row">
        <div class="stat-card green">
          <div class="stat-label">Cash Collected</div>
          <div class="stat-value">${fmt(totalCash)}</div>
          <div class="stat-sub">${collectionRate}% of revenue</div>
        </div>
        <div class="stat-card blue">
          <div class="stat-label">Total Revenue</div>
          <div class="stat-value">${fmt(totalRevenue)}</div>
          <div class="stat-sub">${opportunities.length} won deals</div>
        </div>
        <div class="stat-card amber">
          <div class="stat-label">Balance Owing</div>
          <div class="stat-value">${fmt(totalBalance)}</div>
          <div class="stat-sub">${planCount} on payment plans</div>
        </div>
      </div>

      <div class="progress-card">
        <div class="progress-header">
          <span class="progress-title">Collection Rate · Cash vs Revenue</span>
          <span class="progress-pct">${collectionRate}%</span>
        </div>
        <div class="progress-track">
          <div class="progress-fill" style="width: ${Math.min(collectionRate, 100)}%"></div>
        </div>
        <div class="progress-labels">
          <span>${fmt(totalCash)} collected</span>
          <span>${fmt(totalRevenue)} total</span>
        </div>
      </div>

      <div class="table-card">
        <div class="table-header-row">
          <span class="th">Client</span>
          <span class="th">Revenue</span>
          <span class="th">Collected</span>
          <span class="th">Owing</span>
          <span class="th">Status</span>
        </div>
        ${opportunities.map(opp => {
          const cash = parseAmount(getField(opp, CASH_COLLECTED_FIELD_ID));
          const balance = parseAmount(getField(opp, BALANCE_OWING_FIELD_ID));
          return `
          <div class="table-row">
            <span class="td name">${opp.name}</span>
            <span class="td muted">${fmt(opp.monetaryValue)}</span>
            <span class="td green">${fmt(cash)}</span>
            <span class="td ${balance > 0 ? 'red' : 'muted'}">${balance > 0 ? fmt(balance) : '—'}</span>
            <span class="td">${getBadge(opp)}</span>
          </div>`;
        }).join('')}
      </div>

      <div class="insight-card">
        <div class="insight-icon">◈</div>
        <div class="insight-text">
          <strong>${pifCount} clients</strong> paid in full · 
          <strong>${planCount} clients</strong> on payment plans · 
          <strong>${fmt(totalBalance)}</strong> outstanding balance to collect
        </div>
      </div>

      <div class="last-updated">Last updated: ${now}</div>
    `;
  } catch (e) {
    document.getElementById('app').innerHTML = `<div class="error">Error loading data: ${e.message}</div>`;
  }
}

loadData();
</script>
</body>
</html>
